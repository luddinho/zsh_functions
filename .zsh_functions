#!/bin/bash

# Load all split zsh function files from this repository.
# This file is meant to be sourced from .zshrc.

ZSH_FUNCTIONS_DIR="${${(%):-%N}:A:h}"

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_archive" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_archive"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_dummy" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_dummy"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_general" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_general"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_network" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_network"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_spinner" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_spinner"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_rsync" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_rsync"
fi

if [[ -f "$ZSH_FUNCTIONS_DIR/.zsh_functions_sshkey" ]]; then
	source "$ZSH_FUNCTIONS_DIR/.zsh_functions_sshkey"
fi

unset ZSH_FUNCTIONS_DIR
